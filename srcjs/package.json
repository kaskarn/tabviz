{
  "name": "tabviz-js",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte.mjs"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export.mjs"
    },
    "./spec": {
      "types": "./dist/spec/index.d.ts",
      "import": "./dist/spec.mjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.config.split.ts && vite build --config vite.config.v8.ts",
    "build:widget": "vite build",
    "build:split": "vite build --config vite.config.split.ts",
    "build:v8": "vite build --config vite.config.v8.ts",
    "build:npm": "vite build --config vite.config.npm.ts && tsc -p tsconfig.npm.json && node scripts/rewrite-dts-aliases.mjs",
    "build:npm:types": "tsc -p tsconfig.npm.json && node scripts/rewrite-dts-aliases.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test && vitest run",
    "test:bun": "bun test",
    "test:vitest": "vitest run",
    "lint": "eslint src --ext .ts,.svelte",
    "format": "prettier --write 'src/**/*.{ts,svelte,css}'",
    "screenshot": "node scripts/screenshot.js"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-array": "^3.2.0",
    "@types/d3-format": "^3.0.0",
    "@types/d3-interpolate": "^3.0.0",
    "@types/d3-scale": "^4.0.0",
    "@types/d3-shape": "^3.1.0",
    "@vitest/browser": "^4.1.6",
    "bun-types": "^1.3.5",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "puppeteer": "^24.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "d3-array": "^3.0.0",
    "d3-format": "^3.0.0",
    "d3-interpolate": "^3.0.0",
    "d3-scale": "^4.0.0",
    "d3-shape": "^3.0.0"
  }
}
