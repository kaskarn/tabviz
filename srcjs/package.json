{
  "name": "@tabviz/core",
  "version": "0.5.0",
  "type": "module",
  "description": "Interactive forest plots and rich tables — JavaScript runtime for the tabviz R package",
  "homepage": "https://github.com/kaskarn/tabviz",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaskarn/tabviz.git",
    "directory": "srcjs"
  },
  "bugs": "https://github.com/kaskarn/tabviz/issues",
  "license": "MIT",
  "author": "Antoine Baldassari <baldassarian@gmail.com>",
  "keywords": [
    "forest-plot",
    "meta-analysis",
    "table",
    "svelte",
    "visualization",
    "htmlwidgets"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "**/*.css",
    "**/schema/init.ts",
    "**/schema/init-dom.ts",
    "**/schema/columns/*-behaviors.ts",
    "**/schema/columns/*-renderer.ts",
    "**/schema/columns/*-renderers.ts"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte.mjs"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export.mjs"
    },
    "./spec": {
      "types": "./dist/spec/index.d.ts",
      "import": "./dist/spec.mjs"
    },
    "./extend": {
      "types": "./dist/extend/index.d.ts",
      "import": "./dist/extend.mjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build:npm && npm run check:size && npm run check:lockfiles",
    "build": "vite build && vite build --config vite.config.split.ts && vite build --config vite.config.v8.ts",
    "build:widget": "vite build",
    "build:split": "vite build --config vite.config.split.ts",
    "build:v8": "vite build --config vite.config.v8.ts",
    "build:harness": "vite build --config vite.config.harness.ts",
    "dev:harness": "vite serve --config vite.config.harness.ts",
    "harness:drive": "node tests/components/drive.mjs",
    "build:npm": "vite build --config vite.config.npm.ts && tsc -p tsconfig.npm.json && node scripts/rewrite-dts-aliases.mjs && node scripts/dist-smoke.mjs",
    "build:npm:types": "tsc -p tsconfig.npm.json && node scripts/rewrite-dts-aliases.mjs",
    "check:size": "node scripts/bundle-size-gate.mjs",
    "check:lockfiles": "npm install --package-lock-only --no-audit --no-fund --dry-run && bun install --frozen-lockfile --dry-run",
    "check:wiring": "node scripts/check-primitive-wiring.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.json && node scripts/check-primitive-wiring.mjs",
    "test": "bun test && vitest run",
    "test:bun": "bun test",
    "test:vitest": "vitest run",
    "bench": "bun run tests/perf/run-bench.ts",
    "bench:browser": "bun run tests/browser/run-bench.ts",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.{ts,svelte,css}'",
    "screenshot": "node scripts/screenshot.js"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-array": "^3.2.0",
    "@types/d3-format": "^3.0.0",
    "@types/d3-interpolate": "^3.0.0",
    "@types/d3-scale": "^4.0.0",
    "@types/d3-shape": "^3.1.0",
    "@vitest/browser": "^4.1.6",
    "bun-types": "^1.3.5",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "puppeteer": "^24.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "d3-array": "^3.0.0",
    "d3-format": "^3.0.0",
    "d3-interpolate": "^3.0.0",
    "d3-scale": "^4.0.0",
    "d3-shape": "^3.0.0"
  }
}
